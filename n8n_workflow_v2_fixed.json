            ]
        },
        {
            "parameters": {
                "method": "POST",
                "url": "https://wsdfsdf-travel-assistant-backend.nkfiyw.easypanel.host/api/webhook/location",
                "sendBody": true,
                "specifyBody": "json",
                "jsonBody": "={{ JSON.stringify({ user_id: $json.body.key.remoteJid.split('@')[0], latitude: $json.body.message.locationMessage.degreesLatitude, longitude: $json.body.message.locationMessage.degreesLongitude }) }}",
                "options": {
                    "timeout": 30000
                }
            },
            "id": "node-http-location",
            "name": "Enviar Localização p/ IA",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4,
            "position": [
                650,
                500
            ]
        },
        {
            "parameters": {
                "method": "POST",
                "url": "https://wsdfsdf-travel-assistant-backend.nkfiyw.easypanel.host/api/chat",
                "sendBody": true,
                "specifyBody": "json",
                "jsonBody": "={{ JSON.stringify({ user_id: $json.body.key.remoteJid.split('@')[0], message: $json.body.message.conversation || $json.body.message.extendedTextMessage?.text || '' }) }}",
                "options": {
                    "timeout": 60000
                }
            },
            "id": "node-http-texto",
            "name": "Enviar Texto p/ IA",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4,
            "position": [
                650,
                300
            ]
        },
        {
            "parameters": {
                "respondWith": "json",
                "responseBody": "={ \"status\": \"ok\" }",
                "options": {}
