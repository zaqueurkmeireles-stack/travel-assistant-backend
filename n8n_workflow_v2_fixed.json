                        {
                            "id": "cond-is-media",
                            "leftValue": "={{ $json.body.message.documentMessage || $json.body.message.imageMessage }}",
                            "rightValue": "",
                            "operator": {
                                "type": "string",
                                "operation": "notEmpty"
                            }
                        }
                    ],
                    "combinator": "and"
                },
                "options": {}
            },
            "id": "node-if-midia",
            "name": "É Mídia?",
