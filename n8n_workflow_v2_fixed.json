                "sendBody": true,
                "specifyBody": "json",
                "jsonBody": "={{ JSON.stringify({ user_id: $json.body.key.remoteJid.split('@')[0], base64: $json.body.base64, filename: $json.body.message.documentMessage?.fileName || 'imagem.jpg', mimetype: $json.body.message.documentMessage?.mimetype || $json.body.message.imageMessage?.mimetype }) }}",
                "options": {
                    "timeout": 30000
                }
            },
            "id": "node-http-midia",
            "name": "Enviar Mídia p/ IA",
